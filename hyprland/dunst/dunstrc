[global]
    ### Display ###
    monitor = 0
    follow = mouse

    ### Geometry ###
    width = 380
    height = (0, 300)
    origin = bottom-right
    offset = 12x12
    scale = 0
    notification_limit = 0

    ### Progress bar ###
    progress_bar = true
    progress_bar_height = 6
    progress_bar_frame_width = 0
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 999

    ### Appearance ###
    transparency = 12
    separator_height = 1
    padding = 14
    horizontal_padding = 14
    text_icon_padding = 12
    frame_width = 1
    frame_color = "#12121e"
    gap_size = 8
    separator_color = frame
    sort = yes
    corner_radius = 16
    corners = all

    ### Font ###
    font = Hack Nerd Font 11

    ### Text ###
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    ### Icons ###
    icon_corner_radius = 8
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48

    ### History ###
    sticky_history = yes
    history_length = 20

    ### Misc ###
    dmenu = /usr/bin/rofi -p dunst
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    ignore_dbusclose = false
    keyboard_shortcuts = yes

    ### Wayland ###
    force_xwayland = false
    layer = overlay

    ### Mouse ###
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#06060ae0"
    foreground = "#a6adc8"
    frame_color = "#ffffff12"
    timeout = 1

[urgency_normal]
    background = "#06060ae0"
    foreground = "#a6adc8"
    frame_color = "#ffffff12"
    timeout = 2

[urgency_critical]
    background = "#06060ae0"
    foreground = "#e0e6ff"
    frame_color = "#89b4fa"
    timeout = 0

